        "class<discord|Discord|vesktop|Vesktop>": "ΎΘ┐",
        "class<Slack|slack>": "ΎΗα",
        "class<TelegramDesktop|telegram-desktop|org\\.telegram\\.desktop>": "ΎΜΗ",
        "class<Signal|signal>": "ΎΒ╡",

